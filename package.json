{
  "name": "featuretoggle-sdk-react",
  "version": "1.0.10",
  "private": false,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feature-toggle/sdk-react.git"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "INTEGRATION.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "bun run --filter featuretoggle-sdk-typescript build && bun run test:ci",
    "test:ci": "bun test --preload ./test/preload.ts",
    "lint": "eslint .",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "check-types": "tsc --noEmit",
    "verify": "bun run format:check && bun run lint && bun run check-types && bun run test:ci"
  },
  "peerDependencies": {
    "react": ">=18",
    "featuretoggle-sdk-typescript": "^1.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@eslint/js": "^9.28.0",
    "@happy-dom/global-registrator": "^20.0.10",
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.2.0",
    "eslint": "^9.28.0",
    "featuretoggle-sdk-typescript": "^1.0.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1"
  }
}
